# AWS Bedrock (bearer token auth -- no IAM keys needed)
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_bearer_token
AWS_REGION=us-east-1

# Composio v3 REST API (handles Instagram auth)
COMPOSIO_API_KEY=ak_your_composio_api_key
COMPOSIO_CONNECTED_ACCOUNT_ID=ca_your_connected_account_id
COMPOSIO_USER_ID=your_composio_user_id
INSTAGRAM_USER_ID=your_instagram_user_id

# Cloudinary (image hosting -- Instagram requires public URLs from trusted CDNs)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# S3 bucket for Nova Reel video output (only needed if using Reels)
S3_VIDEO_BUCKET=s3://your-bucket/instagram-reels/

# Content Settings
NICHE=ai_creativity_and_prompts
CONTENT_TYPES=tip,trick,showcase,tutorial,insight
