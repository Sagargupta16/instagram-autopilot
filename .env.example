# AWS Bedrock (bearer token auth -- no IAM keys needed)
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_bearer_token
AWS_REGION=us-east-1

# Composio SDK (handles Instagram + X/Twitter auth)
COMPOSIO_API_KEY=your_composio_api_key
COMPOSIO_CONNECTED_ACCOUNT_ID=instagram_vick-udder
INSTAGRAM_USER_ID=your_instagram_user_id

# imgbb (free image hosting -- Instagram requires public URLs)
IMGBB_API_KEY=your_imgbb_api_key

# S3 bucket for Nova Reel video output (only needed if using Reels)
S3_VIDEO_BUCKET=s3://your-bucket/instagram-reels/

# Content Settings
NICHE=psychology_facts
CONTENT_TYPES=fact,tip
